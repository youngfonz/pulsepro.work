{
  "name": "pulse-trackr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:setup": "bash scripts/dev-setup.sh",
    "build": "prisma generate && node prisma/deploy.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "node prisma/safe-push.mjs",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:migrate": "npx prisma migrate dev",
    "migrate-images": "npx tsx scripts/migrate-images.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:public": "npx playwright test tests/e2e/1.1 tests/e2e/1.2 tests/e2e/1.3 tests/e2e/3.3",
    "test:e2e:api": "npx playwright test tests/e2e/3.2",
    "test:e2e:auth": "npx playwright test tests/e2e/2.0",
    "test:e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@clerk/nextjs": "^6.37.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@polar-sh/nextjs": "^0.9.3",
    "@prisma/client": "^5.22.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.0.1",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.97",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.2",
    "svix": "^1.86.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/dom-speech-recognition": "^0.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
